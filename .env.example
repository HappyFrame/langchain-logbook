# LangChain API Key Configuration
# Copy this file to .env and fill in the blanks

# OpenAI API Key (if needed)
# OPENAI_API_KEY=sk-...

# DeepSeek API Key (recommended)
# DEEPSEEK_API_KEY=...

# LangChain Trace (for LangSmith)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...
# LANGCHAIN_PROJECT=langchain-logbook

# Other environment variables
# PYTHON-PATH=src/
